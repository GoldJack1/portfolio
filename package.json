{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "dev:visual-editor": "node scripts/dev-with-content-watch.mjs 3000",
    "build": "npm run copy-cms && npm run sync-content && next build",
    "copy-cms": "mkdir -p public/admin/vendor && cp node_modules/decap-cms/dist/decap-cms.js public/admin/vendor/decap-cms.js",
    "sync-content": "node scripts/sync-projects.mjs && node scripts/sync-site-pages.mjs && node scripts/sync-site-settings.mjs && node scripts/sync-cms-nav-pages.mjs",
    "sync-projects": "node scripts/sync-projects.mjs",
    "postinstall": "npm run copy-cms",
    "start": "next start",
    "lint": "eslint",
    "extract-icon-metrics": "node scripts/extract-font-metrics.mjs",
    "copy-static-icons": "node scripts/copy-static-icons.mjs"
  },
  "dependencies": {
    "decap-cms": "^3.14.1",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@stackbit/cms-git": "^1.0.38",
    "@stackbit/types": "^2.1.15",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fontkit": "^2.0.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
